# Credentials (API keys, OAuth tokens) are now managed via the dashboard
# Settings page and stored in data/credentials.json.
# ANTHROPIC_API_KEY in .env is still supported for backward compatibility
# and will be auto-migrated to the credential store on first startup.

# API Server
API_PORT=3001

# Dashboard
DASHBOARD_PORT=3000

# Split deployment: set this to the API server's address when running
# the dashboard on a different machine than the API + agents.
# Example: VITE_API_URL=http://192.168.1.50:3001
# VITE_API_URL=

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Default model
DEFAULT_MODEL=claude-haiku-4-5-20251001
